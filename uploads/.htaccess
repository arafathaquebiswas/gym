# Uploaded files must stay readable (product/gallery/member photos) but
# never be executed as scripts — prevents malicious file uploads from running.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<FilesMatch "\.(php|php\d|phtml|phar|pl|py|cgi|asp|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
